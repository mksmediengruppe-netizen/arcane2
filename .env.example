# ============================================================
# ARCANE 2 — Environment Configuration Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to version control
# ============================================================

# --- Server ---
ARCANE_ENV=production
ARCANE_DEBUG=false
ARCANE_HOST=0.0.0.0
ARCANE_PORT=8900
ARCANE_DOMAIN=your-domain.com
ARCANE_SECRET_KEY=your-secret-key-min-32-chars

# --- Strategy ---
DEFAULT_MODEL_STRATEGY=balance   # options: speed | quality | balance | budget
DEFAULT_BUDGET_LIMIT=5.0         # max $ per task before escalation stops

# --- PostgreSQL ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=arcane
POSTGRES_USER=arcane
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql://arcane:your-postgres-password@127.0.0.1:5432/arcane

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# --- MinIO (object storage for artifacts) ---
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=arcane-artifacts
MINIO_SECURE=false

# --- Qdrant (vector DB for agent memory) ---
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=arcane_memory
QDRANT_URL=http://127.0.0.1:6333

# --- LLM Providers ---
# OpenRouter — main routing hub for Claude, GPT, Gemini, etc.
# Get key at: https://openrouter.ai
OPENAI_API_KEY=sk-proj-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=sk-or-v1-...

# --- Search APIs ---
TAVILY_API_KEY=tvly-...        # https://tavily.com
SERPER_API_KEY=...             # https://serper.dev
PEXELS_API_KEY=...             # https://pexels.com/api (free stock images)
EXA_API_KEY=                   # optional
BRAVE_API_KEY=                 # optional

# --- Deploy target (SSH for DevOps tasks) ---
DEFAULT_VPS_HOST=your-server-ip
DEFAULT_VPS_USER=root
DEFAULT_VPS_KEY_PATH=~/.ssh/id_rsa

# --- Rate Limiting ---
MAX_PARALLEL_PROJECTS=3
RATE_LIMIT_OPENAI_RPM=60
RATE_LIMIT_OPENROUTER_RPM=30
RATE_LIMIT_OPENAI_TPM=800000
RATE_LIMIT_OPENROUTER_TPM=400000

# --- Self-Healing ---
MAX_HEAL_ITERATIONS=5
MAX_TIER_ESCALATIONS=2
SANDBOX_TIMEOUT=60

# --- Security ---
JWT_SECRET=your-jwt-secret-min-32-chars

# --- Feature Flags ---
FEATURE_FLAG_LEGACY_CODER=false
